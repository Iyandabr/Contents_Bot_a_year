# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Pexels (featured images — free at pexels.com/api) ─────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ── Cron secret (optional — set to secure the /api/publish and /api/refresh endpoints) ──
CRON_SECRET=your_random_secret_here

# ── How many posts to refresh per site per 12-hour run (2–5 recommended) ─────
REFRESH_LIMIT=3

# ── Freshness sweep ─────────────────────────────────────────────────────────────
# Max posts per site to rewrite per freshness run (posts still anchored to an
# old year with no mention of the current target year). Default: 2.
FRESHNESS_LIMIT=2

# ── Telegram alerting (optional) ────────────────────────────────────────────────
# Reuse the same bot/token/chat as opportunitybot-pro if you want alerts from
# both bots in one place, or create a separate bot via @BotFather for this one.
# If either is unset, Telegram alerting is a no-op.
TELEGRAM_BOT_TOKEN=123456789:your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Slack alerting (optional, can run alongside Telegram) ─────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Google Search Console (optional — feeds topic selection with real query data) ─
# Same service account as opportunitybot-pro works fine — just add its email as
# a Restricted user on the Fulloaded Search Console property too, then reuse the
# same JSON key here. See opportunitybot-pro/.env.example for full setup steps.
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ── WordPress sites (JSON array) ──────────────────────────────────────────────
# Add as many sites as you want. Each site gets:
#   - 1 new post per day (via /api/publish)
#   - 2-5 old posts refreshed every 12 hours (via /api/refresh)
#
# Fields:
#   name           – display name (used for persona lookup)
#   url            – WordPress site URL (no trailing slash)
#   username       – WordPress username
#   password       – Application Password (spaces OK)
#   allCategoryIds – array of WP category IDs for random selection
#   status         – "publish" | "draft"
#   niche          – optional forced niche (jobs_immigration, travel, education, immigration)
#   uniqueContent  – true = always generate unique content for this site
WP_SITES=[{"name":"Fulloaded","url":"https://fulloaded.co.za","username":"user","password":"y06v qdso KF1r 5RT6 EHyW XaWT","allCategoryIds":[366,2,3,380,367,4,381,5,378],"status":"publish","niche":"jobs_immigration","uniqueContent":true}]
